import csv

def carregar_grafo(arquivo_nos, arquivo_arestas):
    grafo = {}

    # Lê os nós
    with open(arquivo_nos, "r", encoding="utf-8") as arquivo:
        leitor = csv.DictReader(arquivo)

        for linha in leitor:
            cidade = linha["Id"]
            grafo[cidade] = []

    # Lê as arestas
    with open(arquivo_arestas, "r", encoding="utf-8") as arquivo:
        leitor = csv.DictReader(arquivo)

        for linha in leitor:
            origem = linha["Source"]
            destino = linha["Target"]
            distancia = float(linha["Distance_km"])

            grafo[origem].append((destino, distancia))
            grafo[destino].append((origem, distancia))

    return grafo


grafo = carregar_grafo(
    "DADOS/D8_cidades_pe_nodes.csv",
    "DADOS/D8_cidades_pe.csv")


print(grafo)
print("Quantidade de cidades:", len(grafo))
